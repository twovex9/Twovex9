{
  "name": "besa-suite-etf",
  "version": "1.0.0",
  "private": true,
  "description": "BS1 — vanilla HTML/JS + Supabase BESA suite (interne ETF tool)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/minify.mjs && node scripts/bust-cache.mjs",
    "build:bust": "node scripts/bust-cache.mjs",
    "build:check": "node scripts/bust-cache.mjs --check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "esbuild": "0.28.1"
  }
}
